#!/usr/bin/env bash
set -euo pipefail

profile="${1:-}"
shift || true

session_config_bin="${VEILKEY_SESSION_CONFIG_BIN:-/usr/local/bin/veilkey-session-config}"
observe_bin="${VEILKEY_PROXY_BIN:-/usr/local/bin/veilkey-proxy}"
unit_prefix="${VEILKEY_VEILROOT_UNIT_PREFIX:-$("$session_config_bin" veilroot-unit-prefix)}"

if [[ -n "$profile" ]]; then
  :
else
  profile="$("$session_config_bin" veilroot-default-profile)"
fi

scope_name="${VEILKEY_VEILROOT_SCOPE:-${unit_prefix}-${profile}}"
cgroup_root="${VEILKEY_VEILROOT_CGROUP_ROOT:-/sys/fs/cgroup/system.slice}"
scope_path="${cgroup_root}/${scope_name}.scope"
wait_seconds="${VEILKEY_VEILROOT_WAIT_SECONDS:-10}"

for _ in $(seq 1 "$wait_seconds"); do
  if [[ -d "$scope_path" ]]; then
    exec "$observe_bin" observe --cgroup "$scope_path" --format json --only-suspicious --enforce-kill "$@"
  fi
  sleep 1
done

echo "veilroot scope did not appear: $scope_path" >&2
exit 1
