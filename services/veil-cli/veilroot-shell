#!/usr/bin/env bash
set -euo pipefail

user_name="${VEILROOT_USER:-veilroot}"
session_launcher="${VEILKEY_VEILROOT_LAUNCHER:-/usr/local/bin/veilkey-veilroot-session}"
session_config_bin="${VEILKEY_SESSION_CONFIG_BIN:-/usr/local/bin/veilkey-session-config}"
veilkey_bin="${VEILKEY_BIN:-/usr/local/bin/veilkey}"
locale_lib="${VEILKEY_LOCALE_LIB:-/usr/local/lib/veilkey/veilkey-locale.sh}"
profile_active="${VEILKEY_VEILROOT_PROFILE_ACTIVE:-/etc/profile.d/${user_name}-veilkey-proxy.sh}"
profile_disabled="${VEILKEY_VEILROOT_PROFILE_DISABLED:-${profile_active}.disabled}"

if [[ -f "$locale_lib" ]]; then
  # shellcheck disable=SC1090
  source "$locale_lib"
fi

_vk_msg() {
  local key="${1:-}"
  local fallback="${2:-$key}"
  shift 2 || true
  if declare -F vk_msg >/dev/null 2>&1; then
    vk_msg "$key" "$@"
  else
    printf '%s' "$fallback"
  fi
}

sanitize_exported_urls() {
  local key value
  for key in VEILKEY_PROXY_URL HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY VEILKEY_LOCALVAULT_URL VEILKEY_KEYCENTER_URL VEILKEY_API; do
    value="${!key-}"
    [[ -n "${value}" ]] || continue
    value="${value#\'}"
    value="${value%\'}"
    export "${key}=${value}"
  done
}

usage() {
  cat <<'EOF'
usage:
  veilroot-shell
  veilroot-shell open [profile]
  veilroot-shell status
  veilroot-shell proxy on
  veilroot-shell proxy off
  veilroot-shell proxy status
EOF
}

vaultcenter_url() {
  local profile
  profile="$(default_profile)"
  "$session_config_bin" tool-shell-exports "$profile" | awk -F= '$1=="export VEILKEY_KEYCENTER_URL"{gsub(/^'\''|'\''$/,"",$2); print $2; exit}'
}

veilkey_connection_status() {
  local url
  url="$(vaultcenter_url)"
  if [[ -z "$url" ]]; then
    printf '%s' "disconnected"
    return
  fi
  if env -u HTTP_PROXY -u HTTPS_PROXY -u ALL_PROXY curl --noproxy '*' -fsS --max-time 2 "${url%/}/health" >/dev/null 2>&1; then
    printf '%s' "connected"
  else
    printf '%s' "disconnected"
  fi
}

proxy_guard_status() {
  if [[ -f "$profile_active" ]]; then
    printf '%s' "enabled"
  else
    printf '%s' "disabled"
  fi
}

observer_status() {
  if systemctl --quiet is-active "$(observe_unit)"; then
    printf '%s' "connected"
  else
    printf '%s' "disconnected"
  fi
}

print_status_banner() {
  local vk_status guard_status obs_status
  vk_status="$(veilkey_connection_status)"
  guard_status="$(proxy_guard_status)"
  obs_status="$(observer_status)"

  if [[ "$vk_status" == "connected" ]]; then
    printf '%s\n' "$(_vk_msg veilroot_connected 'VeilKey: connected')"
  else
    printf '%s\n' "$(_vk_msg veilroot_disconnected 'VeilKey: disconnected')"
  fi

  if [[ "$guard_status" == "enabled" ]]; then
    printf '%s\n' "$(_vk_msg proxy_guard_enabled 'VeilKey Proxy Guard: enabled')"
  else
    printf '%s\n' "$(_vk_msg proxy_guard_disabled 'VeilKey Proxy Guard: disabled')"
  fi

  if [[ "$obs_status" == "connected" ]]; then
    printf '%s\n' "$(_vk_msg observer_connected 'VeilKey Observer: connected')"
  else
    printf '%s\n' "$(_vk_msg observer_disconnected 'VeilKey Observer: disconnected')"
  fi

  printf '%s\n' "$(_vk_msg warn_sudo_all_1 'WARNING: veilroot has sudo ALL privileges.')"
  printf '%s\n' "$(_vk_msg warn_sudo_all_2 'WARNING: all actions are attributable to the current operator.')"
  printf '%s\n' "$(_vk_msg warn_sudo_all_3 'WARNING: use veilroot only for intentional privileged operations.')"
}

default_profile() {
  "$session_config_bin" veilroot-default-profile
}

observe_unit() {
  local profile
  profile="$(default_profile)"
  printf '%s' "${VEILKEY_VEILROOT_OBSERVE_UNIT:-veilkey-veilroot-observe@${profile}.service}"
}

guard_unit() {
  local profile
  profile="$(default_profile)"
  printf '%s' "${VEILKEY_VEILROOT_GUARD_UNIT:-veilkey-veilroot-egress-guard@${profile}.service}"
}

open_session() {
  local profile="${1:-}"
  if [[ -z "$profile" ]]; then
    profile="$(default_profile)"
  fi

  if [[ "${USER:-}" == "$user_name" ]]; then
    print_status_banner
    exec bash -lc '
      profile="$1"
      session_config_bin="$2"
      veilkey_bin="$3"
      quote="$(printf "\\047")"
      eval "$("$session_config_bin" tool-shell-exports "$profile")"
      for key in VEILKEY_PROXY_URL HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY VEILKEY_LOCALVAULT_URL VEILKEY_KEYCENTER_URL VEILKEY_API; do
        value="${!key-}"
        [[ -n "$value" ]] || continue
        value="${value//$quote/}"
        export "${key}=${value}"
      done
      export VEILKEY_VERIFIED_SESSION=1
      export VEILKEY_VEILROOT=1
      export VEILKEY_VEILROOT_PROFILE="$profile"
      exec "$veilkey_bin" wrap-pty bash -li
    ' _ "$profile" "$session_config_bin" "$veilkey_bin"
  fi

  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    echo "veilroot-shell open requires root or the ${user_name} account." >&2
    echo "Use: sudo veilroot-shell open ${profile}" >&2
    exit 1
  fi

  print_status_banner
  exec su -s /bin/bash - "$user_name" -c "exec bash -lc 'profile=\"\$1\"; session_config_bin=\"\$2\"; veilkey_bin=\"\$3\"; quote=\"\$(printf \"\\\\047\")\"; eval \"\$(\"\$session_config_bin\" tool-shell-exports \"\$profile\")\"; for key in VEILKEY_PROXY_URL HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY VEILKEY_LOCALVAULT_URL VEILKEY_KEYCENTER_URL VEILKEY_API; do value=\"\${!key-}\"; [[ -n \"\$value\" ]] || continue; value=\"\${value//\$quote/}\"; export \"\${key}=\$value\"; done; export VEILKEY_VERIFIED_SESSION=1; export VEILKEY_VEILROOT=1; export VEILKEY_VEILROOT_PROFILE=\"\$profile\"; exec \"\$veilkey_bin\" wrap-pty bash -li' _ '$profile' '$session_config_bin' '$veilkey_bin'"
}

proxy_status() {
  local observe_unit guard_unit
  observe_unit="$(observe_unit)"
  guard_unit="$(guard_unit)"
  print_status_banner
  systemctl is-enabled "$observe_unit" 2>/dev/null | sed 's/^/observe_unit_enabled=/' || true
  systemctl is-active "$observe_unit" 2>/dev/null | sed 's/^/observe_unit_active=/' || true
  systemctl is-enabled "$guard_unit" 2>/dev/null | sed 's/^/guard_unit_enabled=/' || true
  systemctl is-active "$guard_unit" 2>/dev/null | sed 's/^/guard_unit_active=/' || true
}

proxy_on() {
  local observe_unit guard_unit
  observe_unit="$(observe_unit)"
  guard_unit="$(guard_unit)"
  if [[ -f "$profile_disabled" ]] && [[ ! -f "$profile_active" ]]; then
    mv "$profile_disabled" "$profile_active"
  fi
  systemctl enable --now "$observe_unit" "$guard_unit"
  proxy_status
}

proxy_off() {
  local observe_unit guard_unit
  observe_unit="$(observe_unit)"
  guard_unit="$(guard_unit)"
  if [[ -f "$profile_active" ]]; then
    mv "$profile_active" "$profile_disabled"
  fi
  systemctl disable --now "$observe_unit" "$guard_unit" || true
  proxy_status
}

case "${1:-}" in
  "")
    open_session
    ;;
  open)
    open_session "${2:-}"
    ;;
  status)
    proxy_status
    ;;
  proxy)
    case "${2:-}" in
      on) proxy_on ;;
      off) proxy_off ;;
      status|"") proxy_status ;;
      *) usage; exit 2 ;;
    esac
    ;;
  *)
    usage
    exit 2
    ;;
esac
