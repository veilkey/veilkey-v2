#!/usr/bin/env bash
set -euo pipefail

veilkey_cli_bin="${VEILKEY_CLI_BIN:-/usr/local/bin/veilkey-cli}"
vk_bin="${VEILKEY_VK_BIN:-/usr/local/bin/vk}"
session_config_bin="${VEILKEY_SESSION_CONFIG_BIN:-/usr/local/bin/veilkey-session-config}"

clear_proxy_overrides() {
  unset VEILKEY_PROXY_URL HTTP_PROXY HTTPS_PROXY ALL_PROXY http_proxy https_proxy all_proxy
}

trim_wrapping_quotes() {
  local value="$1"
  while [[ "${value}" == \"*\" && "${value}" == *\" ]]; do
    value="${value#\"}"
    value="${value%\"}"
  done
  while [[ "${value}" == \'*\' && "${value}" == *\' ]]; do
    value="${value#\'}"
    value="${value%\'}"
  done
  printf '%s' "${value}"
}

usage() {
  cat <<'EOF'
Usage:
  veilkey session [command...]         Start a protected session or run a command via wrap-pty
  veilkey status                       Show VeilKey status
  veilkey paste-mode [on|off|status]   Control standalone pasted temp issuance
  veilkey encrypt                      Encrypt plaintext into a VeilKey ref
  veilkey resolve <VK:ref>             Resolve a VeilKey ref
  veilkey scan [args...]               Run secret scan
  veilkey filter [args...]             Run secret filter
  veilkey exec [args...]               Resolve refs and execute command
  veilkey proxy [args...]              Run local egress proxy
  veilkey help                         Show this help
EOF
}

sanitize_exported_env() {
  local key value
  for key in VEILKEY_PROXY_URL HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY VEILKEY_LOCALVAULT_URL VEILKEY_KEYCENTER_URL VEILKEY_API VEILKEY_PLAINTEXT_ACTION; do
    value="${!key-}"
    [[ -n "${value}" ]] || continue
    value="$(trim_wrapping_quotes "${value}")"
    export "${key}=${value}"
  done
}

load_session_env() {
  if [[ ! -x "${session_config_bin}" ]]; then
    echo "veilkey: required session config binary not found: ${session_config_bin}" >&2
    exit 1
  fi

  clear_proxy_overrides
  eval "$("${session_config_bin}" shell-exports)"
  sanitize_exported_env
}

if [[ ! -x "${veilkey_cli_bin}" ]]; then
  echo "veilkey: required CLI binary not found: ${veilkey_cli_bin}" >&2
  exit 1
fi

cmd="${1:-help}"
case "${cmd}" in
  help|-h|--help)
    usage
    ;;
  session)
    shift
    exec -a veil "${veilkey_cli_bin}" wrap-pty "$@"
    ;;
  status|paste-mode|scan|filter|exec|resolve|proxy|list|clear|function|version)
    shift
    load_session_env
    exec "${veilkey_cli_bin}" "${cmd}" "$@"
    ;;
  encrypt)
    shift
    if [[ ! -x "${vk_bin}" ]]; then
      echo "veilkey: required vk helper not found: ${vk_bin}" >&2
      exit 1
    fi
    exec "${vk_bin}" "$@"
    ;;
  wrap|wrap-pty)
    shift
    load_session_env
    exec -a veil "${veilkey_cli_bin}" "${cmd}" "$@"
    ;;
  *)
    load_session_env
    exec "${veilkey_cli_bin}" "${cmd}" "${@:2}"
    ;;
esac
