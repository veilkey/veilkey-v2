#!/usr/bin/env bash
set -euo pipefail

locale_lib="${VEILKEY_LOCALE_LIB:-/usr/local/lib/veilkey/veilkey-locale.sh}"
if [[ -f "$locale_lib" ]]; then
  # shellcheck disable=SC1090
  source "$locale_lib"
fi
if declare -F vk_msg >/dev/null 2>&1; then
  echo "$(vk_msg direct_tool_blocked curl)" >&2
  echo "$(vk_msg use_proxy_hint)" >&2
else
  echo "[veilkey veilroot] direct curl is blocked." >&2
  echo "[veilkey veilroot] use 'veilkey proxy ...' for outbound API requests." >&2
fi
exit 126
