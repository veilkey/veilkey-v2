#!/usr/bin/env bash
set -euo pipefail

session_name="${VEIL_WORK_TMUX_SESSION:-main}"
tools_csv="${VEIL_WORK_TMUX_TOOLS:-shell,claude,codex}"

IFS=',' read -r -a tools <<<"${tools_csv}"

veil_bin="${VEIL_WORK_TMUX_VEIL_BIN:-veil}"
shell_cmd="${VEIL_WORK_TMUX_SHELL_CMD:-${veil_bin}}"
claude_cmd="${VEIL_WORK_TMUX_CLAUDE_CMD:-${veil_bin}}"
codex_cmd="${VEIL_WORK_TMUX_CODEX_CMD:-${veil_bin}}"
opencode_cmd="${VEIL_WORK_TMUX_OPENCODE_CMD:-${veil_bin}}"

cmd_for_tool() {
  case "${1}" in
    shell) printf '%s\n' "${shell_cmd}" ;;
    claude) printf '%s\n' "${claude_cmd}" ;;
    codex) printf '%s\n' "${codex_cmd}" ;;
    opencode) printf '%s\n' "${opencode_cmd}" ;;
    *) printf '%s\n' "${shell_cmd}" ;;
  esac
}

if [[ "${VEIL_WORK_TMUX_DRY_RUN:-0}" == "1" ]]; then
  printf 'tmux has-session -t %q 2>/dev/null || tmux new-session -d -s %q -n %q %q\n' "${session_name}" "${session_name}" "${tools[0]:-shell}" "$(cmd_for_tool "${tools[0]:-shell}")"
  for tool in "${tools[@]:1}"; do
    printf 'tmux new-window -t %q -n %q %q\n' "${session_name}" "${tool}" "$(cmd_for_tool "${tool}")"
  done
  printf 'exec tmux attach -t %q\n' "${session_name}"
  exit 0
fi

if ! tmux has-session -t "${session_name}" 2>/dev/null; then
  tmux new-session -d -s "${session_name}" -n "${tools[0]:-shell}" "$(cmd_for_tool "${tools[0]:-shell}")"
  for tool in "${tools[@]:1}"; do
    tmux new-window -t "${session_name}" -n "${tool}" "$(cmd_for_tool "${tool}")"
  done
fi

exec tmux attach -t "${session_name}"
