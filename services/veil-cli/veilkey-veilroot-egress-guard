#!/usr/bin/env bash
set -euo pipefail

profile="${1:-}"
action="${2:-apply}"
session_config_bin="${VEILKEY_SESSION_CONFIG_BIN:-/usr/local/bin/veilkey-session-config}"
if [[ -n "${IPTABLES_BIN:-}" ]]; then
  iptables_bin="$IPTABLES_BIN"
else
  iptables_bin="$(command -v iptables-nft 2>/dev/null || command -v iptables)"
fi
if [[ -n "${IP6TABLES_BIN:-}" ]]; then
  ip6tables_bin="$IP6TABLES_BIN"
else
  ip6tables_bin="$(command -v ip6tables-nft 2>/dev/null || command -v ip6tables)"
fi
cgroup_root="${VEILKEY_VEILROOT_CGROUP_ROOT:-/sys/fs/cgroup/system.slice}"
match_path_override="${VEILKEY_VEILROOT_MATCH_PATH:-}"

if [[ -z "$profile" ]]; then
  profile="$($session_config_bin veilroot-default-profile)"
fi
unit_prefix="${VEILKEY_VEILROOT_UNIT_PREFIX:-$($session_config_bin veilroot-unit-prefix)}"
scope_name="${VEILKEY_VEILROOT_SCOPE:-${unit_prefix}-${profile}.scope}"
cgroup_path="${cgroup_root%/}/${scope_name}"
if [[ -n "$match_path_override" ]]; then
  match_path="$match_path_override"
elif [[ "$cgroup_path" == /sys/fs/cgroup/* ]]; then
  match_path="${cgroup_path#/sys/fs/cgroup}"
else
  match_path="/system.slice/${scope_name}"
fi
if [[ "$match_path" != /* ]]; then
  match_path="/$match_path"
fi
safe_profile="$(printf '%s' "$profile" | tr '[:lower:]-' '[:upper:]_')"
chain4="VK_VEILROOT_${safe_profile}_EGRESS"
chain6="VK_VEILROOT_${safe_profile}_EGRESS6"

scope_exists() {
  [[ -d "$cgroup_path" ]]
}

ensure_chain4() {
  "$iptables_bin" -w -N "$chain4" 2>/dev/null || true
  "$iptables_bin" -w -F "$chain4"
  "$iptables_bin" -w -A "$chain4" -o lo -j RETURN
  "$iptables_bin" -w -A "$chain4" -d 10.0.0.0/8 -j RETURN
  "$iptables_bin" -w -A "$chain4" -d 172.16.0.0/12 -j RETURN
  "$iptables_bin" -w -A "$chain4" -d 192.168.0.0/16 -j RETURN
  "$iptables_bin" -w -A "$chain4" -d 100.64.0.0/10 -j RETURN
  "$iptables_bin" -w -A "$chain4" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN
  "$iptables_bin" -w -A "$chain4" -j REJECT --reject-with icmp-admin-prohibited
  "$iptables_bin" -w -C OUTPUT -m cgroup --path "$match_path" -j "$chain4" 2>/dev/null ||     "$iptables_bin" -w -I OUTPUT 1 -m cgroup --path "$match_path" -j "$chain4"
}

ensure_chain6() {
  "$ip6tables_bin" -w -N "$chain6" 2>/dev/null || true
  "$ip6tables_bin" -w -F "$chain6"
  "$ip6tables_bin" -w -A "$chain6" -o lo -j RETURN
  "$ip6tables_bin" -w -A "$chain6" -d ::1/128 -j RETURN
  "$ip6tables_bin" -w -A "$chain6" -m conntrack --ctstate ESTABLISHED,RELATED -j RETURN
  "$ip6tables_bin" -w -A "$chain6" -j REJECT --reject-with icmp6-adm-prohibited
  "$ip6tables_bin" -w -C OUTPUT -m cgroup --path "$match_path" -j "$chain6" 2>/dev/null ||     "$ip6tables_bin" -w -I OUTPUT 1 -m cgroup --path "$match_path" -j "$chain6"
}

remove_chain4() {
  "$iptables_bin" -w -D OUTPUT -m cgroup --path "$match_path" -j "$chain4" 2>/dev/null || true
  "$iptables_bin" -w -F "$chain4" 2>/dev/null || true
  "$iptables_bin" -w -X "$chain4" 2>/dev/null || true
}

remove_chain6() {
  "$ip6tables_bin" -w -D OUTPUT -m cgroup --path "$match_path" -j "$chain6" 2>/dev/null || true
  "$ip6tables_bin" -w -F "$chain6" 2>/dev/null || true
  "$ip6tables_bin" -w -X "$chain6" 2>/dev/null || true
}

status_chain() {
  "$iptables_bin" -w -S OUTPUT | sed -n "/${chain4}/p"
  "$iptables_bin" -w -S "$chain4" 2>/dev/null || true
  echo '---'
  "$ip6tables_bin" -w -S OUTPUT | sed -n "/${chain6}/p"
  "$ip6tables_bin" -w -S "$chain6" 2>/dev/null || true
}

watch_guard() {
  guard_applied=0
  cleanup_watch_guard() {
    if [[ ${guard_applied:-0} -eq 1 ]]; then
      remove_chain4
      remove_chain6
    fi
  }
  trap cleanup_watch_guard EXIT INT TERM
  while true; do
    if scope_exists; then
      if [[ ${guard_applied:-0} -eq 0 ]]; then
        ensure_chain4
        ensure_chain6
        guard_applied=1
      fi
    else
      if [[ ${guard_applied:-0} -eq 1 ]]; then
        remove_chain4
        remove_chain6
        guard_applied=0
      fi
    fi
    sleep 1
  done
}

case "$action" in
  apply)
    ensure_chain4
    ensure_chain6
    ;;
  remove)
    remove_chain4
    remove_chain6
    ;;
  status)
    status_chain
    ;;
  watch)
    watch_guard
    ;;
  *)
    echo "usage: $(basename "$0") [profile] {apply|remove|status|watch}" >&2
    exit 2
    ;;
esac
