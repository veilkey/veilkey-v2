#!/bin/bash
set -euo pipefail

found=0

GO_SERVICES="services/localvault services/vaultcenter"
RUST_SERVICES="services/veil-cli"
ALL_SERVICES="$GO_SERVICES $RUST_SERVICES"

# 1. 하드코딩된 기본값 차단 (Go, Rust, Dockerfile, sh)
BANNED=(
  ":10180"
  ":10181"
  "/opt/veilkey"
  "/etc/veilkey"
  "/usr/local/bin/veilkey"
)

for val in "${BANNED[@]}"; do
  matches=$(grep -rn \
    --include="*.go" \
    --include="*.rs" \
    --include="Dockerfile" \
    --include="*.sh" \
    "$val" $ALL_SERVICES 2>/dev/null || true)
  if [[ -n "$matches" ]]; then
    echo "❌ 하드코딩 금지: '$val'"
    echo "$matches"
    found=1
  fi
done

# 2. 하드코딩 ref 조합 차단 — makeRef()/db.MakeRef()를 사용하세요
ref_hardcoded=$(grep -rn --include="*.go" \
  -E '"V[KE]:" \+|"V[KE]:[A-Z]+:" \+|fmt\.Sprintf\("V[KE]:' $GO_SERVICES 2>/dev/null || true)
if [[ -n "$ref_hardcoded" ]]; then
  echo "❌ 하드코딩 ref 금지: makeRef() 또는 db.MakeRef()를 사용하세요"
  echo "$ref_hardcoded"
  found=1
fi

# 3. executor 결정론 차단 — chain/executor.go에서 time.Now 호출 금지
executor_time=$(grep -rn 'time\.Now' services/vaultcenter/internal/chain/executor.go 2>/dev/null | grep -v '// ' || true)
if [[ -n "$executor_time" ]]; then
  echo "❌ executor 결정론 위반: chain/executor.go에서 time.Now() 금지 — env.Timestamp를 사용하세요"
  echo "$executor_time"
  found=1
fi

# 4. 매직 스트링 차단 — constants.go에 정의된 값이 다른 Go 파일에서 리터럴로 중복 사용
magic_found=""
for cfile in $(find $GO_SERVICES -name "constants.go" -o -name "const.go" 2>/dev/null); do
  pkg_dir=$(dirname "$cfile")
  # constants.go에서 "문자열" 리터럴 추출 (= "..." 패턴)
  consts=$(grep -oP '=\s*"[^"]*"' "$cfile" 2>/dev/null | sed 's/.*"\(.*\)"/\1/' | grep -v '^$' || true)
  for val in $consts; do
    # 같은 패키지 내 다른 .go 파일에서 이 리터럴이 직접 사용되면 위반
    dupes=$(grep -rn --include="*.go" "\"${val}\"" "$pkg_dir" 2>/dev/null | grep -v "constants.go\|const.go" || true)
    if [[ -n "$dupes" ]]; then
      magic_found="${magic_found}\n${dupes}"
    fi
  done
done
if [[ -n "$magic_found" ]]; then
  echo "❌ 매직 스트링 금지: constants.go에 정의된 값을 상수로 참조하세요"
  echo -e "$magic_found"
  found=1
fi

# 3b. 내부 config key 하드코딩 차단 — "_" 프리픽스 config key는 상수로 정의하세요
internal_keys=$(grep -rn --include="*.go" \
  -E '"_[a-z_]+"' $GO_SERVICES 2>/dev/null | \
  grep -v 'constants.go\|const.go\|_test.go\|// ' || true)
if [[ -n "$internal_keys" ]]; then
  echo "❌ 내부 config key 하드코딩 금지: constants.go에 상수로 정의하세요"
  echo "$internal_keys"
  found=1
fi

# 4. sh 파일에서 VEILKEY_* fallback 차단 (${VAR:-} 빈값 제외, 예외 목록 제외)
# *.sh 파일 + 서비스 내 scripts/ 하위의 확장자 없는 스크립트도 포함
_sh_files=$(find $ALL_SERVICES -name "*.sh" -o \( -path "*/scripts/*" -type f ! -name "*.*" \) 2>/dev/null | sort)
sh_fallbacks=$(echo "$_sh_files" | xargs grep -n 'VEILKEY_[A-Z_]*:-[^}]' 2>/dev/null | \
  grep -v 'VEILKEY_VEIL_PROMPT_LABEL\|VEILKEY_STATE_DIR' || true)
if [[ -n "$sh_fallbacks" ]]; then
  echo "❌ sh fallback 금지: VEILKEY_* 기본값을 코드에 박지 마세요"
  echo "$sh_fallbacks"
  found=1
fi

# 3. Go envDefault("VEILKEY_", "value") 패턴 차단 — os.Getenv + 명명된 상수로 대체하세요
go_envdefault=$(grep -rn --include="*.go" \
  'envDefault("VEILKEY_' $ALL_SERVICES 2>/dev/null || true)
if [[ -n "$go_envdefault" ]]; then
  echo "❌ envDefault() 금지: os.Getenv + named const로 대체하세요"
  echo "$go_envdefault"
  found=1
fi

# 5. Dockerfile ENV 기본값 차단
dockerfile_envs=$(grep -rn --include="Dockerfile" \
  '^ENV VEILKEY_' $ALL_SERVICES 2>/dev/null || true)
if [[ -n "$dockerfile_envs" ]]; then
  echo "❌ Dockerfile ENV 기본값 금지: docker-compose 또는 런타임에서 주입하세요"
  echo "$dockerfile_envs"
  found=1
fi

# 6. Rust에서 VEILKEY_* env var에 비어있지 않은 unwrap_or 기본값 차단
# env::var("VEILKEY_FOO").unwrap_or("...") 또는 unwrap_or_else(|_| "...".to_string()) 패턴
rs_fallbacks=$(grep -rn --include="*.rs" \
  'VEILKEY_[A-Z_]*.*\.unwrap_or\b' $RUST_SERVICES 2>/dev/null | \
  grep -v 'unwrap_or_default\|unwrap_or("")\|unwrap_or_else.*unwrap_or_default' || true)
# multi-line: env::var("VEILKEY_*") 뒤에 오는 .unwrap_or_else(|_| "non-empty")
rs_multiline=$(grep -rn --include="*.rs" -A2 \
  'env::var("VEILKEY_' $RUST_SERVICES 2>/dev/null | \
  grep 'unwrap_or_else.*"[^"]' || true)
if [[ -n "$rs_fallbacks" || -n "$rs_multiline" ]]; then
  echo "❌ Rust fallback 금지: VEILKEY_* 기본값을 코드에 박지 마세요"
  [[ -n "$rs_fallbacks" ]] && echo "$rs_fallbacks"
  [[ -n "$rs_multiline" ]] && echo "$rs_multiline"
  found=1
fi

# 7. .env.example에 없는 VEILKEY_* 변수 차단 (Go + sh)
check_env_documented() {
  local service="$1"
  local env_example="services/${service}/.env.example"

  [[ -f "$env_example" ]] || return 0

  used=$(grep -roh 'VEILKEY_[A-Z_]*' "services/${service}" \
    --include="*.go" --include="*.sh" 2>/dev/null \
    | sed 's/.*://' | sort -u)

  documented=$(grep -oh 'VEILKEY_[A-Z_]*' "$env_example" 2>/dev/null | sort -u)

  while IFS= read -r var; do
    [[ -z "$var" ]] && continue
    if ! echo "$documented" | grep -qx "$var"; then
      echo "❌ .env.example 누락: $var (services/${service})"
      found=1
    fi
  done <<< "$used"
}

# 8. docker-compose.yml VEILKEY_* 기본값 차단 (${VEILKEY_FOO:-value} 패턴)
compose_fallbacks=$(grep -n \
  'VEILKEY_[A-Z_]*:-[^}]' docker-compose.yml 2>/dev/null || true)
if [[ -n "$compose_fallbacks" ]]; then
  echo "❌ docker-compose fallback 금지: VEILKEY_* 기본값을 .env.example에 넣고 여기서는 \${VAR} 또는 \${VAR:-}만 사용하세요"
  echo "$compose_fallbacks"
  found=1
fi

check_env_documented "localvault"
check_env_documented "vaultcenter"

# 9. cipher:nonce 인라인 인코딩 차단 — crypto.EncodeCiphertext()/DecodeCiphertext()를 사용하세요
cipher_inline=$(grep -rn --include="*.go" \
  'EncodeToString.*+ ":".*EncodeToString' $GO_SERVICES 2>/dev/null || true)
if [[ -n "$cipher_inline" ]]; then
  echo "❌ cipher:nonce 인라인 인코딩 금지: crypto.EncodeCiphertext()를 사용하세요"
  echo "$cipher_inline"
  found=1
fi
cipher_decode_inline=$(grep -rn --include="*.go" \
  'SplitN.*Ciphertext.*":".*2' $GO_SERVICES 2>/dev/null || true)
if [[ -n "$cipher_decode_inline" ]]; then
  echo "❌ cipher:nonce 인라인 디코딩 금지: crypto.DecodeCiphertext()를 사용하세요"
  echo "$cipher_decode_inline"
  found=1
fi

# 10. 복합 키 직접 연결 차단 — db.MakeTemplateID()/MakeSecretCanonicalID()를 사용하세요
composite_key=$(grep -rn --include="*.go" \
  'VaultHash\s*+\s*":"' $GO_SERVICES 2>/dev/null || true)
composite_key2=$(grep -rn --include="*.go" \
  'VaultRuntimeHash\s*+\s*":"' $GO_SERVICES 2>/dev/null || true)
if [[ -n "$composite_key" || -n "$composite_key2" ]]; then
  echo "❌ 복합 키 직접 연결 금지: db.MakeTemplateID() 또는 db.MakeSecretCanonicalID()를 사용하세요"
  [[ -n "$composite_key" ]] && echo "$composite_key"
  [[ -n "$composite_key2" ]] && echo "$composite_key2"
  found=1
fi

if [[ $found -eq 1 ]]; then
  echo ""
  echo "기본값은 .env.example에 추가하세요."
  exit 1
fi
