[release]
name = "veilkey-core"
version = "2026.03.08"
channel = "stable"

[components.keycenter]
source = "gitlab"
project = "veilkey/veilkey-keycenter"
ref = "fc194ea706e847783e0050a9f987f277e0a8214e"
type = "binary"
install_order = 10
artifact_url = "https://gitlab.ranode.net/api/v4/projects/veilkey%2Fveilkey-keycenter/packages/generic/veilkey-keycenter/fc194ea706e847783e0050a9f987f277e0a8214e/veilkey-keycenter.tar.gz"
sha256 = ""

[components.localvault]
source = "gitlab"
project = "veilkey/veilkey-localvault"
ref = "1778f521624b36b2d7f8034e2788e0994ddc6710"
type = "binary"
install_order = 20
artifact_url = "https://gitlab.ranode.net/api/v4/projects/veilkey%2Fveilkey-localvault/packages/generic/veilkey-localvault/1778f521624b36b2d7f8034e2788e0994ddc6710/veilkey-localvault.tar.gz"
sha256 = ""

[components.proxy]
source = "gitlab"
project = "veilkey/veilkey-proxy"
ref = "670d1e33736adab35149275428ed3aa75b4e787b"
type = "source_archive"
install_order = 30
artifact_url = "https://gitlab.ranode.net/api/v4/projects/veilkey%2Fveilkey-proxy/repository/archive.tar.gz?sha=670d1e33736adab35149275428ed3aa75b4e787b"
artifact_filename = "veilkey-proxy-670d1e33736adab35149275428ed3aa75b4e787b.tar.gz"
sha256 = ""
stage_assets = [
  "deploy/lxc/install-proxy-lxc.sh",
  "deploy/lxc/verify-proxy-lxc.sh",
  "deploy/lxc/veilkey-egress-proxy@.service",
  "deploy/lxc/veilkey-proxy-launch",
  "deploy/shared/veilkey-session-config",
  "deploy/host/session-tools.toml.example",
  "deploy/host/install-veilroot-boundary.sh",
  "deploy/host/install-veilroot-codex.sh",
  "deploy/host/verify-veilroot-session.sh",
  "deploy/host/veilroot-shell",
  "deploy/host/veilkey-veilroot-session",
  "deploy/host/veilkey-veilroot-observe",
  "deploy/host/veilkey-veilroot-egress-guard",
  "deploy/host/veilkey-veilroot-observe@.service",
  "deploy/host/veilkey-veilroot-egress-guard@.service",
  "deploy/host/veilkey-veilroot-curl",
  "deploy/host/veilkey-veilroot-wget",
  "deploy/host/veilkey-veilroot-http",
  "deploy/host/snippets/veilroot-veilkey-shell.sh",
]
post_install_verify = [
  "/usr/local/lib/veilkey-proxy/verify-proxy-lxc.sh",
  "/usr/local/bin/verify-veilroot-session",
]

[profiles.proxmox-host-cli]
description = "Proxmox host boundary CLI and proxy asset install"
components = ["proxy"]

[profiles.proxmox-host]
description = "Proxmox host install with proxy boundary assets"
components = ["proxy"]

[profiles.proxmox-host-localvault]
description = "Proxmox host install with localvault only"
components = ["localvault"]

[profiles.proxmox-lxc-runtime]
description = "Proxmox LXC runtime install without keycenter"
components = ["localvault"]

[profiles.proxmox-lxc-allinone]
description = "Proxmox LXC all-in-one install with keycenter, localvault, and proxy"
components = ["keycenter", "localvault", "proxy"]
