#!/usr/bin/env bash
set -euo pipefail

session_config_bin="${VEILKEY_SESSION_CONFIG_BIN:-/usr/local/bin/veilkey-session-config}"
systemd_run_bin="${SYSTEMD_RUN_BIN:-systemd-run}"
shell_bin="${SHELL_BIN:-bash}"

profile="${1:-}"
if [[ -n "$profile" ]]; then
  shift
else
  profile="$("$session_config_bin" veilroot-default-profile)"
fi

unit_prefix="${VEILKEY_VEILROOT_UNIT_PREFIX:-$("$session_config_bin" veilroot-unit-prefix)}"
scope_name="${VEILKEY_VEILROOT_SCOPE:-${unit_prefix}-${profile}}"
scope_unit="${scope_name}.scope"

if systemctl --quiet is-active "$scope_unit"; then
  echo "veilroot scope is already active: $scope_unit" >&2
  exit 1
fi
systemctl stop "$scope_unit" >/dev/null 2>&1 || true
systemctl reset-failed "$scope_unit" >/dev/null 2>&1 || true

mapfile -t exports < <("$session_config_bin" tool-shell-exports "$profile")

args=("$systemd_run_bin" --quiet --scope --unit "$scope_name" --working-directory "$HOME/workspace")
for line in "${exports[@]}"; do
  kv="${line#export }"
  args+=(--setenv "$kv")
done
args+=(--setenv "VEILKEY_VERIFIED_SESSION=1" --setenv "VEILKEY_VEILROOT=1" --setenv "VEILKEY_VEILROOT_PROFILE=$profile")

if [[ $# -eq 0 ]]; then
  args+=("$shell_bin" -lc 'env | grep -E "^(VEILKEY_PROXY_URL|HTTP_PROXY|HTTPS_PROXY|ALL_PROXY|NO_PROXY|VEILKEY_VERIFIED_SESSION|VEILKEY_VEILROOT|VEILKEY_VEILROOT_PROFILE)=" | sort; echo ---; cat /proc/self/cgroup')
else
  args+=("$@")
fi

exec "${args[@]}"
