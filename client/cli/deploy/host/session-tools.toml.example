[proxy.default]
listen = ""
url = ""
no_proxy = ""
plaintext_action = "issue-temp-and-block"
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.codex]
listen = ""
url = ""
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.claude]
listen = ""
url = ""
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.opencode]
listen = ""
url = ""
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[tools.codex]
bin = "/usr/bin/codex"
proxy = "default"

[tools.claude]
bin = "/root/.local/bin/claude"
proxy = "default"

[tools.opencode]
bin = "/root/.opencode/bin/opencode"
proxy = "default"

[veilroot]
default_profile = "codex"
unit_prefix = "veilroot"

[veilkey]
localvault_url = ""
keycenter_url = ""

# Environment examples:
#   export VEILKEY_LOCALE=ko
#   export VEILKEY_LOCALE=en
