[proxy.default]
listen = "127.0.0.1:18080"
url = "http://127.0.0.1:18080"
no_proxy = "127.0.0.1,localhost,.internal.example,.vhost.example"
plaintext_action = "issue-temp-and-block"
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.codex]
listen = "127.0.0.1:18081"
url = "http://127.0.0.1:18081"
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.claude]
listen = "127.0.0.1:18082"
url = "http://127.0.0.1:18082"
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

[proxy.tools.opencode]
listen = "127.0.0.1:18083"
url = "http://127.0.0.1:18083"
plaintext_action = "issue-temp-and-block"
plaintext_resolve_hosts = []
allow_hosts_enabled = false
allow_hosts = []

# Example:
# keep the global default as block, but let one profile resolve-only for a
# tightly scoped host during a migration window.
#
# [proxy.tools.codex]
# plaintext_resolve_hosts = ["api.openai.com"]

[tools.codex]
bin = "/usr/bin/codex"
proxy = "codex"

[tools.claude]
bin = "/root/.local/bin/claude"
proxy = "claude"

[tools.opencode]
bin = "/root/.opencode/bin/opencode"
proxy = "opencode"

[veilroot]
default_profile = "codex"
unit_prefix = "veilroot"

[veilkey]
localvault_url = "http://127.0.0.1:10180"
keycenter_url = "http://hub.veilkey.example:10180"

# Environment examples:
#   export VEILKEY_LOCALE=ko
#   export VEILKEY_LOCALE=en
