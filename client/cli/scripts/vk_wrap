#!/bin/bash
# vk_wrap — VeilKey controlled terminal environment
# All output from this shell has secrets automatically replaced with VK:hash
# PTY allocation ensures interactive programs (claude, codex, etc.) work correctly
#
# Usage:
#   vk_wrap              Enter interactive shell (all output masked)
#   vk_wrap claude       Run claude directly in masked environment
#
# Environment:
#   VEILKEY_LOCALVAULT_URL  Preferred localvault URL
#   VEILKEY_API             Legacy endpoint variable (fallback)
#   VEILKEY_CLI_BIN      veilkey-cli binary path (auto-detected)

set -euo pipefail

resolve_veilkey_url() {
  if [[ -n "${VEILKEY_LOCALVAULT_URL:-}" ]]; then
    echo "$VEILKEY_LOCALVAULT_URL"
    return
  fi
  if [[ -n "${VEILKEY_API:-}" ]]; then
    echo "$VEILKEY_API"
    return
  fi
  if [[ -n "${VK_BASH_API:-}" ]]; then
    echo "$VK_BASH_API"
    return
  fi
  echo ""
}

export VEILKEY_API="$(resolve_veilkey_url)"
if [[ -z "$VEILKEY_API" ]]; then
  echo "Error: VEILKEY_LOCALVAULT_URL, VEILKEY_API, or VK_BASH_API not set" >&2
  exit 1
fi
export VEILKEY_ACTIVE=1

CLI_BIN="${VEILKEY_CLI_BIN:-$(command -v veilkey-cli 2>/dev/null || true)}"
if [[ -z "$CLI_BIN" ]]; then
  echo "Error: veilkey-cli not found" >&2
  exit 1
fi

if ! curl -sf --connect-timeout 2 "${VEILKEY_API}/health" >/dev/null 2>&1; then
  echo "[vk_wrap] Warning: VeilKey endpoint (${VEILKEY_API}) not responding" >&2
fi

echo "[vk_wrap] Entering VeilKey terminal (all output auto-masked)" >&2
echo "[vk_wrap] Type 'exit' to leave" >&2

export VEILKEY_PS1_PREFIX='\[\033[1;36m\]🔒VK\[\033[0m\] '
export PROMPT_COMMAND='echo -ne "\033]0;🔒 VeilKey\007"'
export VEILKEY_CLI_BIN="$CLI_BIN"

if [[ $# -eq 0 ]]; then
  exec "$CLI_BIN" wrap-pty bash --rcfile <(cat <<'RCEOF'
[ -f ~/.bashrc ] && source ~/.bashrc
PS1="${VEILKEY_PS1_PREFIX}${PS1}"
echo -ne "\033]0;🔒 VeilKey\007"

__vk_preexec() {
  [[ "${BASH_COMMAND}" == "${PROMPT_COMMAND}" ]] && return 0
  [[ "${BASH_COMMAND}" == "echo -ne "* ]] && return 0
  if [[ "${BASH_COMMAND}" =~ VK:[0-9a-f]{4,8} ]]; then
    local resolved="${BASH_COMMAND}"
    local vk_re='VK:[0-9a-f]{4,8}'
    local cli="${VEILKEY_CLI_BIN:-veilkey-cli}"
    while [[ "${resolved}" =~ (${vk_re}) ]]; do
      local vk="${BASH_REMATCH[1]}"
      local plain
      plain=$("$cli" resolve "${vk}" 2>/dev/null) || break
      [[ -z "$plain" ]] && break
      resolved="${resolved//${vk}/${plain}}"
    done
    eval "${resolved}"
    return 1
  fi
  return 0
}
trap '__vk_preexec' DEBUG
RCEOF
)
else
  exec "$CLI_BIN" wrap-pty "$@"
fi
