#!/usr/bin/env bash
set -euo pipefail
if [ $# -lt 1 ]; then
  echo "usage: vk <KEY_NAME>" >&2
  echo "  example: vk CLOUDFLARE_API_KEY" >&2
  exit 2
fi
name="$1"
url="${VEILKEY_LOCALVAULT_URL:-${VEILKEY_API:-}}"
url="${url//\'/}"
if [ -z "$url" ]; then
  echo "error: VEILKEY_LOCALVAULT_URL or VEILKEY_API is not set" >&2
  exit 1
fi
read -r -s -p "Secret: " value
echo ""
if [ -z "$value" ]; then
  echo "error: empty input" >&2
  exit 1
fi
json=$(printf '{"plaintext":"%s","name":"%s"}' "$value" "$name")
result=$(/usr/bin/curl --noproxy '*' -sf -X POST "$url/api/encrypt" \
  -H 'Content-Type: application/json' -d "$json" 2>&1) || {
  echo "error: encrypt failed" >&2; exit 1
}
ref=$(echo "$result" | grep -o '"ref":"[^"]*"' | cut -d'"' -f4)
echo "$ref"
